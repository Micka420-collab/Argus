# ============================================================
# SOC Platform — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# === Sécurité JWT ===
# IMPORTANT : SECRET_KEY DOIT être défini et PERSISTANT. Sans valeur, l'API
# en génère une aléatoire à chaque démarrage → tous les jetons sont invalidés
# au redémarrage et le multi-worker casse. Générer : openssl rand -hex 32
SECRET_KEY=CHANGER_MOI_64_CARACTERES_MINIMUM
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Signatures JWT hybrides post-quantiques (Ed25519 + ML-DSA) — pilier CryptoNext
# Ed25519 dérivé de SECRET_KEY (stable). ML-DSA ajouté si liboqs installé.
PQC_JWT=false
PQC_KEYS_DIR=/var/lib/argus/pqc

# === OpenSearch ===
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGER_MOI

# === Redis ===
REDIS_URL=redis://:CHANGER_MOI@redis:6379
REDIS_PASSWORD=CHANGER_MOI

# === Wazuh ===
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=CHANGER_MOI

# === APIs OSINT (optionnel — active l investigation complète) ===
# Créer un compte gratuit sur https://www.abuseipdb.com/
ABUSEIPDB_KEY=

# Créer un compte gratuit sur https://www.virustotal.com/
VIRUSTOTAL_KEY=

# === Freebox (optionnel — surveillance Box internet) ===
FREEBOX_APP_TOKEN=

# === Analyste IA borné (pilier Qevlar) ===
# Le LLM rédige le rapport ; le VERDICT reste 100% déterministe (Python).
# none   = repli heuristique (aucune dépendance, marche toujours)
# ollama = LLM local auto-hébergé (données résidentes / air-gap)
# claude = API Anthropic (qualité maximale)
LLM_PROVIDER=none
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=
ANTHROPIC_API_KEY=
# Déclenche automatiquement l'IA sur les alertes critiques
AI_AUTO_INVESTIGATE=false

# === Égress OSINT anonymisé (pilier Snowpack) ===
# Route les requêtes OSINT/threat-intel par un proxy (Tor) pour masquer l'IP
# réelle du SOC. Nécessite httpx[socks] + un service anon-gateway.
OUTBOUND_PROXY=
OSINT_ANON=false
TOR_CONTROL_URL=

# === Posture post-quantique TLS (pilier CryptoNext) ===
# Groupes d'échange de clés TLS au niveau du reverse proxy (hybride ML-KEM).
TLS_GROUPS=X25519MLKEM768:X25519:secp256r1

# === Réseau ===
SOC_DOMAIN=soc.lan
