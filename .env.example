# ============================================================
# Argus SOC — Variables d'environnement
# Copier en .env et remplir. (Ou utiliser ./install.sh qui génère tout.)
# Règle .env : PAS de commentaire en fin de ligne de valeur — tout ce qui suit
# le « = » fait partie de la valeur.
# ============================================================

# === Sécurité JWT ===
# SECRET_KEY DOIT être défini et PERSISTANT (sinon jetons invalidés à chaque
# redémarrage + multi-worker cassé). Générer : openssl rand -hex 32
SECRET_KEY=CHANGER_MOI_64_CARACTERES_MINIMUM
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# JWT hybride post-quantique (Ed25519 + ML-DSA si liboqs). Ed25519 dérivé de SECRET_KEY.
PQC_JWT=false
PQC_KEYS_DIR=/var/lib/argus/pqc

# === Compte administrateur (créé au premier démarrage) ===
ADMIN_USERNAME=admin
# À changer (ou laisser install.sh en générer un fort) :
ADMIN_PASSWORD=ChangeMe_2024!

# === OpenSearch ===
# Le mot de passe DOIT respecter la policy : >=8 car., 1 maj, 1 min, 1 chiffre,
# 1 caractère spécial. Éviter @ : / # (ils cassent les URLs).
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=ChangeMe_2024!

# === Redis ===
# REDIS_URL doit contenir le même mot de passe que REDIS_PASSWORD (éviter @ : /).
REDIS_PASSWORD=ChangeMe_2024!
REDIS_URL=redis://:ChangeMe_2024!@redis:6379

# === Wazuh ===
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=ChangeMe_2024!

# === Wazuh Dashboard (UI Wazuh optionnelle — profil wazuh-ui) ===
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=ChangeMe_2024!

# === Réseau ===
SOC_DOMAIN=soc.lan
# Interface capturée par Suricata. Sur Proxmox/Ubuntu c'est souvent ens18,
# PAS eth0. Vérifier avec : ip -br link
NETWORK_INTERFACE=ens18

# === APIs OSINT (optionnel — active l'investigation complète) ===
# Comptes gratuits : https://www.abuseipdb.com/  et  https://www.virustotal.com/
ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=

# === Freebox (optionnel — surveillance Box internet) ===
FREEBOX_APP_TOKEN=

# === Analyste IA borné (pilier Qevlar) ===
# none = repli heuristique (aucune dépendance) | ollama = LLM local | claude = API Anthropic
LLM_PROVIDER=none
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=
# Délai max d'un appel LLM. En CPU (sans GPU) un 7B met 30-90 s : gardez >=180.
LLM_TIMEOUT=180
# Durée de maintien du modèle en RAM entre deux appels (évite les rechargements).
LLM_KEEP_ALIVE=30m
ANTHROPIC_API_KEY=
AI_AUTO_INVESTIGATE=false

# === Égress OSINT anonymisé (pilier Snowpack) ===
# Nécessite le profil anon (anon-gateway).
OUTBOUND_PROXY=
OSINT_ANON=false
TOR_CONTROL_URL=

# === Webhooks sortants (sync tickets — n8n/Slack/Jira) ===
WEBHOOK_URL=
WEBHOOK_SECRET=

# === Posture post-quantique TLS (pilier CryptoNext) ===
TLS_GROUPS=X25519MLKEM768:X25519:secp256r1
